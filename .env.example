# ============================================================
# AGENTE PERSONAL DE FRANCO - Configuración
# Copiá este archivo como .env y completá los valores
# ============================================================

# --- Claude API ---
ANTHROPIC_API_KEY=sk-ant-api...

# --- Datos personales de Franco ---
FRANCO_NAME=Franco
FRANCO_COMPANY=Nombre de tu empresa
FRANCO_EMAIL=franco@tuempresa.com
FRANCO_PHONE=+54 9 11 XXXX-XXXX

# --- Google Calendar ---
# Seguí las instrucciones de setup_calendar.py para obtener estos archivos
GOOGLE_CREDENTIALS_PATH=google_credentials.json
GOOGLE_TOKEN_PATH=google_token.json
TIMEZONE=America/Argentina/Buenos_Aires

# --- Email (Gmail con App Password) ---
# Para Gmail: activá "Verificación en dos pasos" y generá una "Contraseña de aplicación"
# en https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASSWORD=tu-app-password-de-16-caracteres

# --- PDF ---
# Carpeta donde se guardan las propuestas generadas
PDF_OUTPUT_DIR=propuestas

# --- WhatsApp Bot (Twilio) ---
# Creá una cuenta en https://www.twilio.com y activá el sandbox de WhatsApp
# en Console > Messaging > Try it out > Send a WhatsApp message
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Puerto del servidor webhook (por defecto 5001)
WHATSAPP_PORT=5001

# Nombre del asistente virtual (como se va a presentar con los clientes)
ASSISTANT_NAME=Sol

# Link de Calendly u otra herramienta para agendar reuniones (opcional)
# Si lo dejás vacío, el bot le dice al cliente que Franco los va a contactar
FRANCO_CALENDAR_LINK=https://calendly.com/tu-usuario

# --- Lista de precios en Google Drive ---
# ID del spreadsheet (lo que va entre /d/ y /edit en la URL)
DRIVE_PRICE_LIST_ID=1ZBPojWq8o-s4HhGqomwiS5IJ3kpjE75ZPk_rnZ4aqOk

# GID de la pestaña especifica (el numero despues de gid= en la URL)
DRIVE_PRICE_LIST_GID=2112474576

# Token de autenticacion (se genera con setup_drive.py)
GOOGLE_DRIVE_TOKEN_PATH=google_drive_token.json

# Cada cuanto se recarga la lista desde Sheets (en segundos, por defecto 1800 = 30 min)
DRIVE_CACHE_TTL=1800

# --- ERP / API de pedidos ---
# URL base del ERP (sin barra final), ej: https://mi-erp.com
CAMPE_API_URL=https://tu-erp.com
# Clave de API (Rails.application.credentials.campe_api_key)
CAMPE_API_KEY=tu-api-key-aqui

# --- Telegram Bot ---
# Token del bot (obtenerlo hablando con @BotFather en Telegram -> /newbot)
TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff

# Tu Telegram user ID para que solo vos puedas usar el bot
# Consultalo hablando con @userinfobot en Telegram
# Podes poner varios separados por coma: 123456,789012
TELEGRAM_ALLOWED_USERS=123456789
